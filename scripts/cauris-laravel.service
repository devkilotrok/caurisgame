[Unit]
Description=Cauris Laravel API Server
After=network.target cauris-xampp.service
Requires=cauris-xampp.service

[Service]
Type=simple
User=adolphe
Group=adolphe
WorkingDirectory=/opt/lampp/htdocs/backendCauris
ExecStart=/usr/bin/env php artisan serve --host=0.0.0.0 --port=8000
Restart=always
RestartSec=3
StandardOutput=append:/home/adolphe/laravel.log
StandardError=append:/home/adolphe/laravel.log

[Install]
WantedBy=multi-user.target

